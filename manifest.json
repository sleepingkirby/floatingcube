{
  "manifest_version": 2,
  "name": "floatingcube",
  "version": "1.0",
  "description": "Noting, finding, easy access to sugarcube variables for sugarcube pages.",
  "browser_specific_settings": {
    "gecko": {
      "id": "sleepingkirby@gmail.com-floatingcube",
      "strict_min_version": "79.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "icons": {
    "96": "icons/placeholder_bow96.png"
  },
  "browser_action": {
    "default_icon": {
      "96":"icons/placeholder_bow96.png"
    },
    "default_title": "floating cube",
    "default_popup": "popup/menu.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["./content_scripts/main.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
